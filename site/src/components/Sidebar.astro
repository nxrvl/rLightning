---
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const currentPath = Astro.url.pathname;

const categories = [
  { key: 'getting-started', label: 'Getting Started', items: ['getting-started', 'quick-start', 'docker'] },
  { key: 'reference', label: 'Reference', items: ['configuration', 'architecture', 'compatibility', 'benchmarks'] },
  { key: 'commands', label: 'Commands', items: [
    'commands/index', 'commands/strings', 'commands/hashes', 'commands/lists',
    'commands/sets', 'commands/sorted-sets', 'commands/streams',
    'commands/bitmap', 'commands/hyperloglog', 'commands/geo',
    'commands/transactions', 'commands/scripting', 'commands/pubsub',
    'commands/acl', 'commands/cluster', 'commands/sentinel', 'commands/server'
  ]},
];

function getDocBySlug(slug: string) {
  return allDocs.find(doc => doc.id === slug);
}

function isActive(slug: string) {
  const path = `/docs/${slug}`;
  return currentPath === path || currentPath === path + '/';
}
---

<aside class="sidebar" id="sidebar">
  <nav class="sidebar-nav">
    {categories.map(cat => (
      <div class="sidebar-section">
        <h3 class="sidebar-heading">{cat.label}</h3>
        <ul class="sidebar-list">
          {cat.items.map(slug => {
            const doc = getDocBySlug(slug);
            if (!doc) return null;
            return (
              <li>
                <a
                  href={`/docs/${slug}`}
                  class:list={['sidebar-link', { active: isActive(slug) }]}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .sidebar {
    position: fixed;
    top: var(--header-height);
    left: 0;
    bottom: 0;
    width: var(--sidebar-width);
    background: var(--bg-secondary);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    padding: 1.5rem 0;
    z-index: 50;
  }

  .sidebar-nav {
    padding: 0 1rem;
  }

  .sidebar-section {
    margin-bottom: 1.5rem;
  }

  .sidebar-heading {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: 0 0.75rem;
    margin-bottom: 0.5rem;
  }

  .sidebar-list {
    list-style: none;
  }

  .sidebar-link {
    display: block;
    padding: 0.375rem 0.75rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    border-radius: var(--radius-sm);
    transition: all 0.15s;
  }

  .sidebar-link:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }

  .sidebar-link.active {
    color: var(--accent);
    background: var(--accent-glow);
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .sidebar {
      display: none;
    }

    .sidebar.open {
      display: block;
      width: 100%;
      max-width: 300px;
      box-shadow: 4px 0 20px rgba(0, 0, 0, 0.3);
    }
  }
</style>
